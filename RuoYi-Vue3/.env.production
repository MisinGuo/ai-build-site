# 页面标题
VITE_APP_TITLE = SEO多站点管理系统

# 生产环境配置
VITE_APP_ENV = 'production'

# 部署子路径配置（如果部署到根路径，设置为 '/'；如果部署到子路径，如 GitHub Pages 的仓库名，设置为 '/your-repo-name/'）
# 例如：部署到 https://username.github.io/game-box/ 则设置为 '/game-box/'
VITE_BASE_PATH = '/'

# SEO多站点管理系统/生产环境
# /prod-api 转发
# https://api.zeusai.top 实际的后端地址
# 下面这个是线上经过cf的地址
VITE_APP_BASE_API = 'http://local.zeusai.top:8890' 

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip