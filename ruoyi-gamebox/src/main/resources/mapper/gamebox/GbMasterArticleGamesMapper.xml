<mapper namespace="com.ruoyi.gamebox.mapper.GbMasterArticleGamesMapper">
    
    <resultMap type="GbMasterArticleGames" id="GbMasterArticleGamesResult">
        <result property="id"    column="id"    />
        <result property="masterArticleId"    column="master_article_id"    />
        <result property="gameId"    column="game_id"    />
        <result property="relationSource"    column="relation_source"    />
        <result property="relationType"    column="relation_type"    />
        <result property="displayOrder"    column="display_order"    />
        <result property="confidenceScore"    column="confidence_score"    />
