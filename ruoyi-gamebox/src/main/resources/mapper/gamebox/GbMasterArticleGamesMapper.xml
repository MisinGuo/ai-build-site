        <result property="reviewedAt"    column="reviewed_at"    />
        <result property="reviewNotes"    column="review_notes"    />
        <result property="isFeatured"    column="is_featured"    />
        <result property="clickCount"    column="click_count"    />
        <result property="lastUsedAt"    column="last_used_at"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectGbMasterArticleGamesVo">
        select id, master_article_id, game_id, relation_source, relation_type, display_order,
               confidence_score, ai_platform_id, ai_reasoning, ai_metadata, review_status,
               reviewed_by, reviewed_at, review_notes, is_featured, click_count, last_used_at,
               del_flag, create_by, create_time, update_by, update_time, remark
        from gb_master_article_games
    </sql>

    <select id="selectByMasterArticleId" resultMap="GbMasterArticleGamesResult">
        <include refid="selectGbMasterArticleGamesVo"/>
        where master_article_id = #{masterArticleId}
          and del_flag = '0'
        order by display_order asc, create_time asc
    </select>

    <select id="selectByGameId" resultMap="GbMasterArticleGamesResult">
        <include refid="selectGbMasterArticleGamesVo"/>
        where game_id = #{gameId}
          and del_flag = '0'
        order by create_time desc
    </select>

    <insert id="insertGbMasterArticleGames" parameterType="GbMasterArticleGames" useGeneratedKeys="true" keyProperty="id">
        insert into gb_master_article_games
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="masterArticleId != null">master_article_id,</if>
            <if test="gameId != null">game_id,</if>
            <if test="relationSource != null">relation_source,</if>
            <if test="relationType != null">relation_type,</if>
            <if test="displayOrder != null">display_order,</if>
            <if test="confidenceScore != null">confidence_score,</if>
            <if test="aiPlatformId != null">ai_platform_id,</if>
            <if test="aiReasoning != null">ai_reasoning,</if>
            <if test="aiMetadata != null">ai_metadata,</if>
            <if test="reviewStatus != null">review_status,</if>
            <if test="reviewedBy != null">reviewed_by,</if>
            <if test="reviewedAt != null">reviewed_at,</if>
            <if test="reviewNotes != null">review_notes,</if>
            <if test="isFeatured != null">is_featured,</if>
            <if test="clickCount != null">click_count,</if>
            <if test="lastUsedAt != null">last_used_at,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="masterArticleId != null">#{masterArticleId},</if>
            <if test="gameId != null">#{gameId},</if>
            <if test="relationSource != null">#{relationSource},</if>
            <if test="relationType != null">#{relationType},</if>
            <if test="displayOrder != null">#{displayOrder},</if>
            <if test="confidenceScore != null">#{confidenceScore},</if>
            <if test="aiPlatformId != null">#{aiPlatformId},</if>
            <if test="aiReasoning != null">#{aiReasoning},</if>
            <if test="aiMetadata != null">#{aiMetadata},</if>
            <if test="reviewStatus != null">#{reviewStatus},</if>
            <if test="reviewedBy != null">#{reviewedBy},</if>
            <if test="reviewedAt != null">#{reviewedAt},</if>
            <if test="reviewNotes != null">#{reviewNotes},</if>
            <if test="isFeatured != null">#{isFeatured},</if>
            <if test="clickCount != null">#{clickCount},</if>
            <if test="lastUsedAt != null">#{lastUsedAt},</if>
