            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <insert id="batchInsertGbMasterArticleGames">
        insert into gb_master_article_games(
            master_article_id, game_id, relation_source, relation_type, display_order,
            del_flag, create_by, create_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (
                #{item.masterArticleId}, #{item.gameId}, #{item.relationSource}, 
                #{item.relationType}, #{item.displayOrder}, '0', #{item.createBy}, now()
            )
        </foreach>
    </insert>

    <update id="updateGbMasterArticleGames" parameterType="GbMasterArticleGames">
        update gb_master_article_games
        <trim prefix="SET" suffixOverrides=",">
            <if test="relationSource != null">relation_source = #{relationSource},</if>
            <if test="relationType != null">relation_type = #{relationType},</if>
            <if test="displayOrder != null">display_order = #{displayOrder},</if>
            <if test="confidenceScore != null">confidence_score = #{confidenceScore},</if>
            <if test="aiPlatformId != null">ai_platform_id = #{aiPlatformId},</if>
            <if test="aiReasoning != null">ai_reasoning = #{aiReasoning},</if>
            <if test="aiMetadata != null">ai_metadata = #{aiMetadata},</if>
            <if test="reviewStatus != null">review_status = #{reviewStatus},</if>
            <if test="reviewedBy != null">reviewed_by = #{reviewedBy},</if>
            <if test="reviewedAt != null">reviewed_at = #{reviewedAt},</if>
            <if test="reviewNotes != null">review_notes = #{reviewNotes},</if>
            <if test="isFeatured != null">is_featured = #{isFeatured},</if>
            <if test="clickCount != null">click_count = #{clickCount},</if>
            <if test="lastUsedAt != null">last_used_at = #{lastUsedAt},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGbMasterArticleGamesById">
        delete from gb_master_article_games where id = #{id}
    </delete>

    <delete id="deleteByMasterArticleId">
        delete from gb_master_article_games where master_article_id = #{masterArticleId}
    </delete>

    <delete id="deleteByMasterArticleIdAndGameId">
        delete from gb_master_article_games 
        where master_article_id = #{masterArticleId} and game_id = #{gameId}
    </delete>

