<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gamebox.mapper.GbSiteTemplateMapper">

    <resultMap type="com.ruoyi.gamebox.domain.GbSiteTemplate" id="GbSiteTemplateResult">
        <result property="id"                 column="id"                  />
        <result property="name"               column="name"                />
        <result property="siteFunctionType"   column="site_function_type"  />
        <result property="industry"           column="industry"            />
        <result property="description"        column="description"         />
        <result property="previewImage"       column="preview_image"       />
        <result property="templateGitUrl"     column="template_git_url"    />
        <result property="templateGitBranch"  column="template_git_branch" />
        <result property="entryDir"           column="entry_dir"           />
        <result property="framework"          column="framework"           />
        <result property="envTemplate"        column="env_template"        />
        <result property="configMappings"     column="config_mappings"     />
        <result property="gitAccountId"       column="git_account_id"      />
        <result property="sortOrder"          column="sort_order"          />
        <result property="status"             column="status"              />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"         column="create_time"         />
        <result property="updateBy"           column="update_by"           />
        <result property="updateTime"         column="update_time"         />
        <result property="remark"             column="remark"              />
    </resultMap>

    <select id="selectTemplateList" parameterType="com.ruoyi.gamebox.domain.GbSiteTemplate" resultMap="GbSiteTemplateResult">
        SELECT * FROM gb_site_templates
        <where>
            <if test="siteFunctionType != null and siteFunctionType != ''">
                AND site_function_type = #{siteFunctionType}
            </if>
            <if test="industry != null and industry != ''">
                AND industry = #{industry}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY sort_order ASC, create_time DESC
    </select>

    <select id="selectTemplateById" parameterType="Long" resultMap="GbSiteTemplateResult">
        SELECT * FROM gb_site_templates WHERE id = #{id}
    </select>

    <insert id="insertTemplate" parameterType="com.ruoyi.gamebox.domain.GbSiteTemplate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO gb_site_templates
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="siteFunctionType != null">site_function_type,</if>
            <if test="industry != null">industry,</if>
            <if test="description != null">description,</if>
            <if test="previewImage != null">preview_image,</if>
            <if test="templateGitUrl != null">template_git_url,</if>
            <if test="templateGitBranch != null">template_git_branch,</if>
            <if test="entryDir != null">entry_dir,</if>
            <if test="framework != null">framework,</if>
            <if test="envTemplate != null">env_template,</if>
            <if test="configMappings != null">config_mappings,</if>
            <if test="gitAccountId != null">git_account_id,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="siteFunctionType != null">#{siteFunctionType},</if>
            <if test="industry != null">#{industry},</if>
            <if test="description != null">#{description},</if>
            <if test="previewImage != null">#{previewImage},</if>
            <if test="templateGitUrl != null">#{templateGitUrl},</if>
            <if test="templateGitBranch != null">#{templateGitBranch},</if>
            <if test="entryDir != null">#{entryDir},</if>
            <if test="framework != null">#{framework},</if>
            <if test="envTemplate != null">#{envTemplate},</if>
            <if test="configMappings != null">#{configMappings},</if>
            <if test="gitAccountId != null">#{gitAccountId},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateTemplate" parameterType="com.ruoyi.gamebox.domain.GbSiteTemplate">
        UPDATE gb_site_templates
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="siteFunctionType != null">site_function_type = #{siteFunctionType},</if>
            <if test="industry != null">industry = #{industry},</if>
            <if test="description != null">description = #{description},</if>
            <if test="previewImage != null">preview_image = #{previewImage},</if>
            <if test="templateGitUrl != null">template_git_url = #{templateGitUrl},</if>
            <if test="templateGitBranch != null">template_git_branch = #{templateGitBranch},</if>
            <if test="entryDir != null">entry_dir = #{entryDir},</if>
            <if test="framework != null">framework = #{framework},</if>
            <if test="envTemplate != null">env_template = #{envTemplate},</if>
            <if test="configMappings != null">config_mappings = #{configMappings},</if>
            <if test="gitAccountId != null">git_account_id = #{gitAccountId},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteTemplateById" parameterType="Long">
        DELETE FROM gb_site_templates WHERE id = #{id}
    </delete>

    <delete id="deleteTemplateByIds" parameterType="Long">
        DELETE FROM gb_site_templates WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
