<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gamebox.mapper.GbPlatformCfAccountMapper">

    <resultMap type="com.ruoyi.gamebox.domain.GbPlatformCfAccount" id="GbPlatformCfAccountResult">
        <result property="id"          column="id"          />
        <result property="name"        column="name"        />
        <result property="accountId"   column="account_id"  />
        <result property="apiToken"    column="api_token"   />
        <result property="isDefault"   column="is_default"  />
        <result property="status"      column="status"      />
        <result property="remark"      column="remark"      />
        <result property="createBy"    column="create_by"   />
        <result property="createTime"  column="create_time" />
        <result property="updateBy"    column="update_by"   />
        <result property="updateTime"  column="update_time" />
    </resultMap>

    <!-- 脱敏查询（列表/下拉不返回原始token） -->
    <sql id="selectMasked">
        id, name, account_id,
        CONCAT(LEFT(api_token, 4), '****', RIGHT(api_token, 4)) AS api_token,
        is_default, status, remark, create_by, create_time, update_by, update_time
    </sql>

    <select id="selectList" parameterType="com.ruoyi.gamebox.domain.GbPlatformCfAccount" resultMap="GbPlatformCfAccountResult">
        SELECT <include refid="selectMasked" /> FROM gb_platform_cf_accounts
        <where>
            <if test="name != null and name != ''">AND name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY is_default DESC, create_time DESC
    </select>

    <select id="selectById" parameterType="Long" resultMap="GbPlatformCfAccountResult">
        SELECT * FROM gb_platform_cf_accounts WHERE id = #{id}
    </select>

    <select id="selectEnabledList" resultMap="GbPlatformCfAccountResult">
        SELECT <include refid="selectMasked" /> FROM gb_platform_cf_accounts
        WHERE status = '1'
        ORDER BY is_default DESC, name ASC
    </select>

    <insert id="insert" parameterType="com.ruoyi.gamebox.domain.GbPlatformCfAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO gb_platform_cf_accounts
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="accountId != null">account_id,</if>
            <if test="apiToken != null">api_token,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="accountId != null">#{accountId},</if>
            <if test="apiToken != null">#{apiToken},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.gamebox.domain.GbPlatformCfAccount">
        UPDATE gb_platform_cf_accounts
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="accountId != null">account_id = #{accountId},</if>
            <if test="apiToken != null and apiToken != '' and !apiToken.contains('****')">api_token = #{apiToken},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        DELETE FROM gb_platform_cf_accounts WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM gb_platform_cf_accounts WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>

    <update id="clearDefault">
        UPDATE gb_platform_cf_accounts SET is_default = '0' WHERE is_default = '1'
    </update>

</mapper>
