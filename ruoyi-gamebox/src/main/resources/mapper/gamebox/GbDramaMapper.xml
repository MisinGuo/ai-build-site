    <sql id="selectGbDramaVo">
        select id, site_id, vendor_id, name, subtitle, category_id, tags, cover_url, cover_horizontal_url, trailer_url, description, content, total_episodes, current_episodes, free_episodes, update_status, episode_price, full_price, unlock_type, view_count, like_count, favorite_count, rating, director, actors, producer, release_date, is_new, is_hot, is_recommend, sort_order, status, del_flag, create_by, create_time, update_by, update_time, remark from gb_dramas
    </sql>

    <select id="selectGbDramaList" parameterType="GbDrama" resultMap="GbDramaResult">
        select d.*,
               c.name as category_name,
               c.icon as category_icon
        from gb_dramas d
        left join gb_categories c on d.category_id = c.id and c.del_flag = '0'
        <where>
            d.del_flag = '0'
            <if test="siteId != null "> and d.site_id = #{siteId}</if>
            <if test="vendorId != null "> and d.vendor_id = #{vendorId}</if>
            <if test="name != null  and name != ''"> and d.name like concat('%', #{name}, '%')</if>
            <if test="categoryId != null "> and d.category_id = #{categoryId}</if>
            <if test="updateStatus != null  and updateStatus != ''"> and d.update_status = #{updateStatus}</if>
            <if test="unlockType != null  and unlockType != ''"> and d.unlock_type = #{unlockType}</if>
            <if test="isNew != null  and isNew != ''"> and d.is_new = #{isNew}</if>
            <if test="isHot != null  and isHot != ''"> and d.is_hot = #{isHot}</if>
            <if test="isRecommend != null  and isRecommend != ''"> and d.is_recommend = #{isRecommend}</if>
            <if test="status != null  and status != ''"> and d.status = #{status}</if>
        </where>
        order by d.sort_order asc, d.create_time desc
    </select>
    
    <select id="selectGbDramaById" parameterType="Long" resultMap="GbDramaResult">
        select d.*, 
               c.id as category_id,
               c.name as category_name,
               c.icon as category_icon
        from gb_dramas d
        left join gb_categories c on d.category_id = c.id and c.del_flag = '0'
        where d.id = #{id} and d.del_flag = '0'
    </select>
        
