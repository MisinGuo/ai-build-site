<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gamebox.mapper.GbTitleImportLogMapper">
    
    <resultMap type="GbTitleImportLog" id="GbTitleImportLogResult">
        <result property="id"    column="id"    />
        <result property="importBatch"    column="import_batch"    />
        <result property="importType"    column="import_type"    />
        <result property="fileName"    column="file_name"    />
        <result property="filePath"    column="file_path"    />
        <result property="totalCount"    column="total_count"    />
        <result property="successCount"    column="success_count"    />
        <result property="failedCount"    column="failed_count"    />
        <result property="duplicateCount"    column="duplicate_count"    />
        <result property="importStatus"    column="import_status"    />
        <result property="errorMessage"    column="error_message"    />
        <result property="importDetails"    column="import_details"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectGbTitleImportLogVo">
        select id, import_batch, import_type, file_name, file_path, total_count, success_count, 
               failed_count, duplicate_count, import_status, error_message, import_details, 
               create_by, create_time 
        from gb_title_import_log
    </sql>

    <select id="selectGbTitleImportLogList" resultMap="GbTitleImportLogResult">
        <include refid="selectGbTitleImportLogVo"/>
        <where>  
            <if test="importBatch != null and importBatch != ''">
                and import_batch = #{importBatch}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectGbTitleImportLogById" parameterType="Long" resultMap="GbTitleImportLogResult">
        <include refid="selectGbTitleImportLogVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertGbTitleImportLog" parameterType="GbTitleImportLog" useGeneratedKeys="true" keyProperty="id">
        insert into gb_title_import_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="importBatch != null">import_batch,</if>
            <if test="importType != null">import_type,</if>
            <if test="fileName != null">file_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="totalCount != null">total_count,</if>
            <if test="successCount != null">success_count,</if>
            <if test="failedCount != null">failed_count,</if>
            <if test="duplicateCount != null">duplicate_count,</if>
            <if test="importStatus != null">import_status,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="importDetails != null">import_details,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="importBatch != null">#{importBatch},</if>
            <if test="importType != null">#{importType},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="totalCount != null">#{totalCount},</if>
            <if test="successCount != null">#{successCount},</if>
            <if test="failedCount != null">#{failedCount},</if>
            <if test="duplicateCount != null">#{duplicateCount},</if>
            <if test="importStatus != null">#{importStatus},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="importDetails != null">#{importDetails},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateGbTitleImportLog" parameterType="GbTitleImportLog">
        update gb_title_import_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="importBatch != null">import_batch = #{importBatch},</if>
            <if test="importType != null">import_type = #{importType},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="totalCount != null">total_count = #{totalCount},</if>
            <if test="successCount != null">success_count = #{successCount},</if>
            <if test="failedCount != null">failed_count = #{failedCount},</if>
            <if test="duplicateCount != null">duplicate_count = #{duplicateCount},</if>
            <if test="importStatus != null">import_status = #{importStatus},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="importDetails != null">import_details = #{importDetails},</if>
        </trim>
        where id = #{id}
    </update>

    <select id="countTotalImports" resultType="int">
        select count(1) from gb_title_import_log
    </select>

</mapper>
