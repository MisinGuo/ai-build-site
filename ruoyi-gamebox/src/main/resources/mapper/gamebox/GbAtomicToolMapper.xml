<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gamebox.mapper.GbAtomicToolMapper">
    
    <resultMap type="GbAtomicTool" id="GbAtomicToolResult">
        <result property="id"    column="id"    />
        <result property="toolCode"    column="tool_code"    />
        <result property="toolName"    column="tool_name"    />
        <result property="toolType"    column="tool_type"    />
        <result property="description"    column="description"    />
        <result property="config"    column="config"    />
        <result property="inputs"    column="inputs"    />
        <result property="outputs"    column="outputs"    />
        <result property="enabled"    column="enabled"    />
        <result property="siteId"    column="site_id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="categoryName"    column="category_name"    />
        <result property="categoryIcon"    column="category_icon"    />
        <result property="relationSource"    column="relation_source"    />
        <result property="isVisible"    column="is_visible"    />
        <result property="relatedSitesCount"    column="related_sites_count"    />
        <result property="excludedSitesCount"    column="excluded_sites_count"    />
        <result property="isExcluded"    column="is_excluded"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectGbAtomicToolVo">
        select id, tool_code, tool_name, tool_type, description, config, inputs, outputs, enabled, site_id, category_id, create_by, create_time, update_by, update_time, remark from gb_atomic_tool
    </sql>

    <select id="selectGbAtomicToolList" parameterType="GbAtomicTool" resultMap="GbAtomicToolResult">
        SELECT 
            t.id, t.tool_code, t.tool_name, t.tool_type, t.description, t.config, 
            t.inputs, t.outputs, t.enabled, t.site_id, t.category_id,
            c.name as category_name, c.icon as category_icon,
            t.create_by, t.create_time, t.update_by, t.update_time, t.remark,
            (SELECT COUNT(*) FROM gb_site_atomic_tool_relations r2 
             WHERE r2.tool_id = t.id AND r2.relation_type = 'include') as related_sites_count,
            (SELECT COUNT(*) FROM gb_site_atomic_tool_relations r3 
             WHERE r3.tool_id = t.id AND r3.relation_type = 'exclude') as excluded_sites_count
            <if test="queryMode == 'related'">
                , CASE 
                    WHEN t.site_id = #{siteId} THEN 'own'
                    WHEN t.site_id = #{params.personalSiteId} THEN 'default'
                    ELSE 'shared'
                END as relation_source
                , CASE 
                    WHEN t.site_id = #{siteId} THEN t.enabled
                    WHEN t.site_id = #{params.personalSiteId} THEN (CASE WHEN incl.id IS NOT NULL THEN incl.is_visible WHEN excl.id IS NULL THEN '1' ELSE '0' END)
                    ELSE COALESCE(incl.is_visible, '0')
                END as is_visible
                , CASE 
                    WHEN t.site_id = #{params.personalSiteId} AND incl.id IS NULL AND excl.id IS NOT NULL THEN 1
                    ELSE 0
                END as is_excluded
            </if>
        FROM gb_atomic_tool t
        LEFT JOIN gb_categories c ON t.category_id = c.id AND c.status = '1'
        <if test="queryMode == 'related'">
            LEFT JOIN gb_site_atomic_tool_relations incl 
                ON t.id = incl.tool_id 
                AND incl.site_id = #{siteId} 
                AND incl.relation_type = 'include'
            LEFT JOIN gb_site_atomic_tool_relations excl 
                ON t.id = excl.tool_id 
                AND excl.site_id = #{siteId} 
                AND excl.relation_type = 'exclude'
        </if>
        <where>
            <choose>
                <!-- 关联网站模式：查看指定网站可见的所有工具 -->
                <when test="queryMode == 'related' and siteId != null">
                    AND (
                        <!-- 1. 该网站自己创建的工具 -->
                        t.site_id = #{siteId}
                        <!-- 2. 用户默认站点配置 -->
                        <if test="params != null and params.personalSiteId != null">
                            OR t.site_id = #{params.personalSiteId}
                        </if>
                        <!-- 3. 其他网站分享的工具 -->
                        OR EXISTS (
                            SELECT 1 FROM gb_site_atomic_tool_relations r3
                            WHERE r3.tool_id = t.id 
                            AND r3.site_id = #{siteId}
                            AND r3.relation_type = 'include'
                        )
                    )
                </when>
                <!-- 创建者模式：查看指定网站创建的工具 -->
                <otherwise>
                    <choose>
                        <when test="siteId != null and includeDefault == true">
                            AND (t.site_id = #{siteId}<if test="params != null and params.personalSiteId != null"> OR t.site_id = #{params.personalSiteId}</if>)
                        </when>
                        <when test="siteId != null and siteId > 0">
                            AND t.site_id = #{siteId}
                        </when>
                        <!-- siteId为null时，用personalSiteId兜底，否则返回空 -->
                        <when test="params != null and params.personalSiteId != null">
                            AND t.site_id = #{params.personalSiteId}
                        </when>
                        <otherwise>
                            AND 1 = 0
                        </otherwise>
                    </choose>
                </otherwise>
            </choose>
            <if test="toolCode != null and toolCode != ''">
                AND t.tool_code = #{toolCode}
            </if>
            <if test="toolName != null and toolName != ''">
                AND t.tool_name LIKE CONCAT('%', #{toolName}, '%')
            </if>
            <if test="toolType != null and toolType != ''">
                AND t.tool_type = #{toolType}
            </if>
            <if test="enabled != null">
                AND t.enabled = #{enabled}
            </if>
            <if test="categoryId != null">
                AND t.category_id = #{categoryId}
            </if>
        </where>
        ORDER BY t.create_time DESC
    </select>
    
    <select id="selectGbAtomicToolById" parameterType="Long" resultMap="GbAtomicToolResult">
        <include refid="selectGbAtomicToolVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertGbAtomicTool" parameterType="GbAtomicTool" useGeneratedKeys="true" keyProperty="id">
        insert into gb_atomic_tool
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="toolCode != null and toolCode != ''">tool_code,</if>
            <if test="toolName != null and toolName != ''">tool_name,</if>
            <if test="toolType != null and toolType != ''">tool_type,</if>
            <if test="description != null">description,</if>
            <if test="config != null">config,</if>
            <if test="inputs != null">inputs,</if>
            <if test="outputs != null">outputs,</if>
            <if test="enabled != null">enabled,</if>
            <if test="siteId != null">site_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="toolCode != null and toolCode != ''">#{toolCode},</if>
            <if test="toolName != null and toolName != ''">#{toolName},</if>
            <if test="toolType != null and toolType != ''">#{toolType},</if>
            <if test="description != null">#{description},</if>
            <if test="config != null">#{config},</if>
            <if test="inputs != null">#{inputs},</if>
            <if test="outputs != null">#{outputs},</if>
            <if test="enabled != null">#{enabled},</if>
            <if test="siteId != null">#{siteId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateGbAtomicTool" parameterType="GbAtomicTool">
        update gb_atomic_tool
        <trim prefix="SET" suffixOverrides=",">
            <if test="toolCode != null and toolCode != ''">tool_code = #{toolCode},</if>
            <if test="toolName != null and toolName != ''">tool_name = #{toolName},</if>
            <if test="toolType != null and toolType != ''">tool_type = #{toolType},</if>
            <if test="description != null">description = #{description},</if>
            <if test="config != null">config = #{config},</if>
            <if test="inputs != null">inputs = #{inputs},</if>
            <if test="outputs != null">outputs = #{outputs},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            <if test="siteId != null">site_id = #{siteId},</if>
            category_id = #{categoryId},
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGbAtomicToolById" parameterType="Long">
        delete from gb_atomic_tool where id = #{id}
    </delete>

    <delete id="deleteGbAtomicToolByIds" parameterType="String">
        delete from gb_atomic_tool where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
