<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gamebox.mapper.GbGameCategoryRelationMapper">
    
    <resultMap type="GbGameCategoryRelation" id="GbGameCategoryRelationResult">
        <result property="id"    column="id"    />
        <result property="gameId"    column="game_id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="isPrimary"    column="is_primary"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="categoryName"    column="category_name"    />
        <result property="categorySlug"    column="category_slug"    />
        <result property="categoryIcon"    column="category_icon"    />
        <result property="gameName"    column="game_name"    />
    </resultMap>

    <sql id="selectGbGameCategoryRelationVo">
        select id, game_id, category_id, sort_order, is_primary, create_by, create_time, update_by, update_time from gb_game_category_relations
    </sql>

    <select id="selectGbGameCategoryRelationList" parameterType="GbGameCategoryRelation" resultMap="GbGameCategoryRelationResult">
        <include refid="selectGbGameCategoryRelationVo"/>
        <where>  
            <if test="gameId != null "> and game_id = #{gameId}</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="isPrimary != null  and isPrimary != ''"> and is_primary = #{isPrimary}</if>
        </where>
        order by sort_order, id
    </select>
    
    <select id="selectGbGameCategoryRelationById" parameterType="Long" resultMap="GbGameCategoryRelationResult">
        <include refid="selectGbGameCategoryRelationVo"/>
        where id = #{id}
    </select>

    <select id="selectCategoriesByGameId" parameterType="Long" resultMap="GbGameCategoryRelationResult">
        select 
            r.id, 
            r.game_id, 
            r.category_id, 
            r.sort_order, 
            r.is_primary,
            c.name as category_name,
            c.slug as category_slug,
            c.icon as category_icon
        from gb_game_category_relations r
        inner join gb_categories c on r.category_id = c.id
        where r.game_id = #{gameId}
        order by r.is_primary desc, r.sort_order, r.id
    </select>

    <select id="selectCategoriesByGameIds" resultMap="GbGameCategoryRelationResult">
        select 
            r.id, 
            r.game_id, 
            r.category_id, 
            r.sort_order, 
            r.is_primary,
            c.name as category_name,
            c.slug as category_slug,
            c.icon as category_icon
        from gb_game_category_relations r
        inner join gb_categories c on r.category_id = c.id
        where r.game_id in
        <foreach collection="gameIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        order by r.game_id, r.is_primary desc, r.sort_order, r.id
    </select>

    <select id="selectCategoryIdsByGameId" parameterType="Long" resultType="Long">
        select category_id
        from gb_game_category_relations
        where game_id = #{gameId}
        order by sort_order, id
    </select>

    <select id="selectGameIdsByCategoryId" parameterType="Long" resultType="Long">
        select game_id
        from gb_game_category_relations
        where category_id = #{categoryId}
        group by game_id
        order by min(sort_order), min(id)
    </select>

    <select id="selectPrimaryCategoryByGameId" parameterType="Long" resultMap="GbGameCategoryRelationResult">
        select 
            r.id, 
            r.game_id, 
            r.category_id, 
            r.sort_order, 
            r.is_primary,
            c.name as category_name,
            c.slug as category_slug,
            c.icon as category_icon
        from gb_game_category_relations r
        inner join gb_categories c on r.category_id = c.id
        where r.game_id = #{gameId} and r.is_primary = '1'
        limit 1
    </select>

    <select id="checkRelationExists" resultMap="GbGameCategoryRelationResult">
        <include refid="selectGbGameCategoryRelationVo"/>
        where game_id = #{gameId} and category_id = #{categoryId}
        limit 1
    </select>

    <insert id="insertGbGameCategoryRelation" parameterType="GbGameCategoryRelation" useGeneratedKeys="true" keyProperty="id">
        insert into gb_game_category_relations
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="gameId != null">game_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="isPrimary != null">is_primary,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="gameId != null">#{gameId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="isPrimary != null">#{isPrimary},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <insert id="batchInsertGbGameCategoryRelation" parameterType="java.util.List">
        insert into gb_game_category_relations
        (game_id, category_id, sort_order, is_primary, create_by, create_time)
        values
        <foreach collection="relations" item="item" separator=",">
            (#{item.gameId}, #{item.categoryId}, #{item.sortOrder}, #{item.isPrimary}, #{item.createBy}, #{item.createTime})
        </foreach>
    </insert>

    <update id="updateGbGameCategoryRelation" parameterType="GbGameCategoryRelation">
        update gb_game_category_relations
        <trim prefix="SET" suffixOverrides=",">
            <if test="gameId != null">game_id = #{gameId},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="isPrimary != null">is_primary = #{isPrimary},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="updatePrimaryCategory">
        update gb_game_category_relations
        set is_primary = case 
            when category_id = #{categoryId} then '1'
            else '0'
        end
        where game_id = #{gameId}
    </update>

    <delete id="deleteGbGameCategoryRelationById" parameterType="Long">
        delete from gb_game_category_relations where id = #{id}
    </delete>

    <delete id="deleteGbGameCategoryRelationByIds" parameterType="String">
        delete from gb_game_category_relations where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteGbGameCategoryRelationByGameId" parameterType="Long">
        delete from gb_game_category_relations where game_id = #{gameId}
    </delete>

    <delete id="deleteGbGameCategoryRelationByCategoryId" parameterType="Long">
        delete from gb_game_category_relations where category_id = #{categoryId}
    </delete>

    <delete id="batchDeleteByGameIds">
        delete from gb_game_category_relations 
        where game_id in
        <foreach item="gameId" collection="gameIds" open="(" separator="," close=")">
            #{gameId}
        </foreach>
    </delete>
</mapper>
