# ==========================================
# 游戏盒子内容管理系统 - 环境配置（.env）
# ==========================================
# 说明：
# - 本文件仅用于【基础设施层】（数据库 / Redis / ES / 端口等）
# - 所有【业务层配置】统一由管理后台写入数据库
# - 本文件可安全用于 docker-compose，不参与业务逻辑
# ==========================================


# =========================
# MySQL 数据库配置
# =========================

# MySQL root 密码
# docker-compose 中优先使用 MYSQL_ROOT_PASSWORD
# 若未设置，则回退使用 MYSQL_PASSWORD（兼容旧配置）
MYSQL_ROOT_PASSWORD=GameBox2025!

# （兼容保留）旧变量名，不强制使用
MYSQL_PASSWORD=GameBox2025!

# 默认创建的数据库名
MYSQL_DATABASE=gamebox


# =========================
# Redis 配置
# =========================

# Redis 访问密码（requirepass）
REDIS_PASSWORD=Redis2025!


# =========================
# 后端服务基础配置
# =========================

# 后端 HTTP 服务端口
BACKEND_PORT=8080


# =========================
# Elasticsearch / 网络代理配置
# =========================
# 仅用于 ES 插件下载 / 外部访问
# 若无代理需求，可留空或删除（ES_JAVA_OPTS 中会自动忽略）

PROXY_HOST=local.zeusai.top
PROXY_PORT=10666
PROXY_USER=misin
PROXY_PASS=misin


# ==========================================
# 以下配置均【不在此文件中管理】
# ==========================================
# 这些配置由【管理后台】写入数据库，并进行加密存储
#
# - GitHub OAuth App
#   → 系统配置表（支持多站点 / 多 App）
#
# - GitHub 仓库连接
#   → 表 gb_github_repos（用户级别）
#
# - AI 平台 API Keys（OpenAI / Claude / etc）
#   → 表 gb_ai_platforms
#
# - 对象存储（S3 / OSS / COS / MinIO）
#   → 表 gb_storage_configs
#
# 说明：
# - 用户在管理后台进行配置
# - 系统统一加密后存储到数据库
# - 避免敏感信息出现在 env / compose / git 中
# ==========================================
